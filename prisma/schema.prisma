generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  STAFF
  PATRON
}

enum TicketStatus {
  NEW
  IN_PROGRESS
  WAITING_APPROVAL
  CLOSED
}

enum TicketType {
  FEATURE_REQUEST
  BUG_FIX
}

enum SchedulerType {
  THERMAL_SCAN
  DITCH_SURVEY
  WEIR_ANALYSIS
  PATRON
}

enum SchedulerStatus {
  NEW_REQUEST
  SCHEDULED
  COMPLETED
}

model User {
  id                String   @id @default(cuid())
  email             String   @unique
  passwordHash      String
  firstName         String
  lastName          String
  address           String
  city              String
  state             String
  zip               String
  phone             String
  role              UserRole @default(PATRON)
  isActive          Boolean  @default(true)
  emailVerified     Boolean  @default(false)
  passwordResetToken String?
  passwordResetExpiry DateTime?
  timezone          String   @default("America/Los_Angeles")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("users")
}

model Patron {
  id                    String   @id @default(cuid())
  accountNumber         String   @unique
  firstName             String?
  lastName              String?
  legalName             String?
  serviceStreet         String
  serviceCity           String
  serviceState          String
  serviceZip            String
  serviceCountry        String   @default("US")
  mailingStreet         String?
  mailingCity           String?
  mailingState          String?
  mailingZip            String?
  mailingCountry        String?
  primaryEmail          String?
  primaryPhone          String?
  totalWaterRightAcres  Float
  assessedAcres         Float
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  notes                 AccountNote[]
  additionalContacts    AdditionalContact[]
  documents             PatronDocument[]
  turnouts              Turnout[]
  generalNotes          Note[]
  transactionItems      TransactionItem[]
  toTransactionItems    TransactionItem[] @relation("ToPatronItems")
  weirBookItems         WeirBookItem[]
  invoices              Invoice[]

  @@map("patrons")
}

model AccountNote {
  id          String   @id @default(cuid())
  patronId    String
  note        String
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  patron      Patron   @relation(fields: [patronId], references: [id], onDelete: Cascade)

  @@map("account_notes")
}

enum ContactType {
  SPOUSE
  CARETAKER
  ADDITIONAL_CONTACT
}

model AdditionalContact {
  id          String      @id @default(cuid())
  patronId    String
  firstName   String
  lastName    String
  email       String?
  mobilePhone String?
  street      String?
  city        String?
  state       String?
  zip         String?
  country     String?
  contactType ContactType @default(ADDITIONAL_CONTACT)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  patron      Patron      @relation(fields: [patronId], references: [id], onDelete: Cascade)

  @@map("additional_contacts")
}

enum DocumentType {
  INFO
  COMPLIANCE
  LEGAL
}

model PatronDocument {
  id           String       @id @default(cuid())
  patronId     String
  documentType DocumentType @default(INFO)
  fileName     String
  s3Key        String
  s3Url        String
  mimeType     String
  fileSize     Int
  description  String?
  uploadedBy   String
  uploadedById String
  createdAt    DateTime     @default(now())

  patron       Patron       @relation(fields: [patronId], references: [id], onDelete: Cascade)

  @@map("patron_documents")
}

model Turnout {
  id                String   @id @default(cuid())
  accountNumber     String
  canal             String   @db.VarChar(255)
  gate              String   @db.VarChar(255)
  use               String?  @db.VarChar(50)
  deliveredAcres     Float
  acresOwned        Float
  taxLotNumber      String   @db.VarChar(255)
  legalDescription  String   @db.VarChar(255)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  patron            Patron   @relation(fields: [accountNumber], references: [accountNumber], onDelete: Cascade)
  notes             Note[]

  @@map("turnouts")
  @@index([accountNumber])
}

model Note {
  id             String   @id @default(cuid())
  patronId       String?
  turnoutId      String?
  ticketId       String?
  schedulerId    String?
  createdBy      String?
  timeReceived   DateTime @default(now())
  notes          String   @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  patron         Patron?  @relation(fields: [patronId], references: [id], onDelete: Cascade)
  turnout        Turnout? @relation(fields: [turnoutId], references: [id], onDelete: Cascade)
  ticket         Ticket?  @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  scheduler      Scheduler? @relation(fields: [schedulerId], references: [id], onDelete: Cascade)

  @@map("notes")
  @@index([patronId])
  @@index([turnoutId])
  @@index([ticketId])
  @@index([schedulerId])
}

model Scheduler {
  id            String          @id @default(cuid())
  scheduleId    Int             @unique @default(autoincrement())
  scheduledTime DateTime
  type          SchedulerType
  status        SchedulerStatus @default(NEW_REQUEST)
  description   String          @db.VarChar(255)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  notes         Note[]
  documents     SchedulerDocument[]

  @@map("scheduler")
  @@index([scheduledTime])
  @@index([status])
  @@index([type])
}

model SchedulerDocument {
  id           String       @id @default(cuid())
  schedulerId  String
  documentType DocumentType @default(INFO)
  fileName     String
  s3Key        String
  s3Url        String
  mimeType     String
  fileSize     Int
  description  String?
  uploadedBy   String
  uploadedById String
  createdAt    DateTime     @default(now())

  scheduler    Scheduler    @relation(fields: [schedulerId], references: [id], onDelete: Cascade)

  @@map("scheduler_documents")
  @@index([schedulerId])
}


model AuditLog {
  id          String   @id @default(cuid())
  tableName   String
  recordId    String
  action      String   // CREATE, UPDATE, DELETE
  changedBy   String   // User ID who made the change
  changes     Json     // JSON object of changed fields
  createdAt   DateTime @default(now())

  @@map("audit_logs")
  @@index([tableName, recordId])
  @@index([changedBy])
  @@index([createdAt])
}

model Ticket {
  id          String       @id @default(cuid())
  ticketNumber Int          @unique
  title       String
  description String
  type        TicketType
  status      TicketStatus @default(NEW)
  priority    String       @default("MEDIUM") // LOW, MEDIUM, HIGH
  assignedTo  String?      // User ID
  createdBy   String       // User ID who created the ticket
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  notes       Note[]

  @@map("tickets")
  @@index([status])
  @@index([assignedTo])
  @@index([createdBy])
  @@index([ticketNumber])
}

model WeirBook {
  id            String        @id @default(cuid())
  weirNumber    String        @unique
  canal         String        @db.VarChar(255)
  weirLocation  Int
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  items         WeirBookItem[]

  @@map("weir_books")
  @@index([weirNumber])
  @@index([canal])
}

model WeirBookItem {
  id              String    @id @default(cuid())
  weirBookId      String
  accountNumber   String?
  acres           Float
  privateAcres    Float
  description     String?   @db.Text
  notes           String?   @db.Text
  imageUrl        String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  weirBook        WeirBook  @relation(fields: [weirBookId], references: [id], onDelete: Cascade)
  patron          Patron?   @relation(fields: [accountNumber], references: [accountNumber], onDelete: Cascade)

  @@map("weir_book_items")
  @@index([weirBookId])
  @@index([accountNumber])
}

enum TransactionType {
  CANCEL
  TRANSFER
  ACTIVE
}

model Transaction {
  id                String          @id @default(cuid())
  transactionNumber String          @unique
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  items             TransactionItem[]

  @@map("transactions")
  @@index([transactionNumber])
}

model TransactionItem {
  id                  String          @id @default(cuid())
  transactionId       String
  accountNumber       String
  type                TransactionType
  toAccountNumber     String?
  parcelNumber        String?         @db.VarChar(25)
  legalDescription    String?         @db.VarChar(255)
  taxLot              String?         @db.VarChar(255)
  subdivision         String?         @db.VarChar(25)
  waterRightAcres     Float?
  transactionDate     DateTime?
  memo                String?         @db.Text
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  transaction         Transaction     @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  patron              Patron          @relation(fields: [accountNumber], references: [accountNumber], onDelete: Cascade)
  toPatron            Patron?         @relation("ToPatronItems", fields: [toAccountNumber], references: [accountNumber], onDelete: Cascade)

  @@map("transaction_items")
  @@index([transactionId])
  @@index([accountNumber])
  @@index([toAccountNumber])
}

enum ChargeType {
  TAXLOT
  ACRE_OF_WATER
  PER_SEASON
}

model RateType {
  id        String   @id @default(cuid())
  name      String   @unique
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  rateItems RateItem[]

  @@map("rate_types")
}

model Rate {
  id        String     @id @default(cuid())
  year      Int
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  items     RateItem[]
  invoices  Invoice[]

  @@map("rates")
  @@index([year])
}

model RateItem {
  id           String     @id @default(cuid())
  rateId       String
  rateTypeId   String
  rateCode     String     @db.VarChar(10)
  chargeType   ChargeType
  assessment   Decimal    @db.Decimal(10, 2)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  rate         Rate       @relation(fields: [rateId], references: [id], onDelete: Cascade)
  rateType     RateType   @relation(fields: [rateTypeId], references: [id])

  @@map("rate_items")
  @@index([rateId])
  @@index([rateTypeId])
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  VOID
}

model Invoice {
  id              String        @id @default(cuid())
  invoiceNumber   String        @unique
  accountNumber   String
  rateId          String
  status          InvoiceStatus @default(DRAFT)
  invoiceDate     DateTime      @default(now())
  dueDate         DateTime?
  firstName       String
  lastName        String
  mailingStreet   String?
  mailingCity     String?
  mailingState    String?
  mailingZip      String?
  serviceStreet   String
  serviceCity     String
  serviceState    String
  serviceZip      String
  totalAmount     Decimal       @db.Decimal(12, 2)
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  patron          Patron        @relation(fields: [accountNumber], references: [accountNumber])
  rate            Rate          @relation(fields: [rateId], references: [id])
  lineItems       InvoiceLineItem[]

  @@map("invoices")
  @@index([accountNumber])
  @@index([rateId])
  @@index([status])
}

model InvoiceLineItem {
  id           String   @id @default(cuid())
  invoiceId    String
  rateItemId   String
  rateCode     String   @db.VarChar(10)
  description  String
  chargeType   ChargeType
  quantity     Decimal  @db.Decimal(12, 4)
  unitPrice    Decimal  @db.Decimal(10, 2)
  lineTotal    Decimal  @db.Decimal(12, 2)
  createdAt    DateTime @default(now())

  invoice      Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_line_items")
  @@index([invoiceId])
}

model NavGroup {
  id        String    @id @default(cuid())
  label     String
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  links     NavLink[]

  @@map("nav_groups")
}

model NavLink {
  id         String    @id @default(cuid())
  groupId    String?
  label      String
  url        String
  sortOrder  Int       @default(0)
  openInNew  Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  group      NavGroup? @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@map("nav_links")
  @@index([groupId])
}

enum PageStatus {
  DRAFT
  PUBLISHED
}

model CmsPage {
  id          String     @id @default(cuid())
  title       String
  slug        String     @unique
  content     String     @db.Text
  status      PageStatus @default(DRAFT)
  metaTitle   String?
  metaDesc    String?
  createdBy   String
  updatedBy   String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("cms_pages")
  @@index([slug])
  @@index([status])
}

model SavedListView {
  id          String   @id @default(cuid())
  name        String
  entityType  String   // "patron", "turnout", etc.
  columns     Json     // Array of column names to display
  filters     Json     // Array of filter criteria { field, operator, value }
  userId      String   // User who created this view
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("saved_list_views")
  @@index([userId])
  @@index([entityType])
}
