# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/arnold_irrigation

# Auth
JWT_SECRET=your-secret-key-here

# AWS (prefix must NOT be AWS_ — reserved by Amplify)
APP_AWS_REGION=us-west-2
APP_AWS_ACCESS_KEY_ID=AKIA...
APP_AWS_SECRET_ACCESS_KEY=...
APP_AWS_S3_BUCKET=your-bucket-name

# Amplify (set these in Amplify Console, not in .env)
# These are examples of what to set in Amplify Console environment variables
# DATABASE_URL=postgresql://USER:PASSWORD@RDS_ENDPOINT:5432/arnold_irrigation
# JWT_SECRET=your-production-secret-key
# APP_AWS_REGION=us-west-2
# APP_AWS_ACCESS_KEY_ID=your-access-key
# APP_AWS_SECRET_ACCESS_KEY=your-secret-key
# APP_AWS_S3_BUCKET=arnold-irrigation
